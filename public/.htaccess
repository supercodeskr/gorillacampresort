RewriteEngine On

# Add trailing slash if request is a directory
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve index.html if the requested path corresponds to a directory containing one
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

# Fallback for Next.js trailingSlash: false (just in case)
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Custom 404 Page (Optional but good)
ErrorDocument 404 /404.html
